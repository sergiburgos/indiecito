# Clave de API para el modelo de IA de Poolside (laguna-m.1)
POOLSIDE_API_KEY="YOUR_POOLSIDE_API_KEY"

# Activa o desactiva la función de gestión de reservas.
# Cambiar a "False" para que el bot solo responda consultas.
RESERVAS_ACTIVAS="True"

# --- Credenciales para la API de Google Calendar ---
# Estas credenciales se obtienen del proceso de autorización de OAuth 2.0
# (normalmente siguiendo la guía de la API de Google).
GOOGLE_CLIENT_ID="YOUR_GOOGLE_CLIENT_ID"
GOOGLE_CLIENT_SECRET="YOUR_GOOGLE_CLIENT_SECRET"
GOOGLE_REFRESH_TOKEN="YOUR_GOOGLE_REFRESH_TOKEN"
