{
  "builds": [
    {
      "src": "api/index.py",
      "use": "@vercel/python",
      "config": {
        "includeFiles": [
          "prompt_base.md",
          "prompt_herramientas_calendario.md",
          "poolside_client.py",
          "google_calendar.py",
          "contacts_manager.py"
        ]
      }
    }
  ],
  "routes": [
    {
      "src": "/(.*)",
      "dest": "api/index.py"
    }
  ]
}